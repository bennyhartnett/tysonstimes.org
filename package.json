{
  "name": "tysons-times",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "content:build": "node scripts/build-content.mjs",
    "content:check": "node scripts/build-content.mjs --check",
    "images:optimize": "node scripts/optimize-source-images.mjs",
    "predev": "npm run content:build",
    "dev": "vite --host 127.0.0.1",
    "preseo": "npm run content:build",
    "seo": "node scripts/generate-seo-assets.mjs",
    "prebuild": "npm run content:build && node scripts/generate-seo-assets.mjs",
