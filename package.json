    "preview": "vite preview --host 127.0.0.1",
    "check": "npm run content:check && npm run build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "sharp": "^0.35.3",
    "vite": "^7.0.0"
  }
}
